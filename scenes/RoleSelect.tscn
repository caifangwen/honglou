[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/RoleSelect.gd" id="1"]

[node name="RoleSelect" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="VBox" type="VBoxContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2

[node name="Title" type="Label" parent="VBox"]
layout_mode = 2
text = "选择你的身份"
horizontal_alignment = 1

[node name="StewardBtn" type="Button" parent="VBox"]
layout_mode = 2
text = "管家"

[node name="MasterBtn" type="Button" parent="VBox"]
layout_mode = 2
text = "主子"

[node name="ServantBtn" type="Button" parent="VBox"]
layout_mode = 2
text = "丫鬟 / 小厮"

[connection signal="pressed" from="VBox/StewardBtn" to="." method="_on_select_steward_pressed"]
[connection signal="pressed" from="VBox/MasterBtn" to="." method="_on_select_master_pressed"]
[connection signal="pressed" from="VBox/ServantBtn" to="." method="_on_select_servant_pressed"]

