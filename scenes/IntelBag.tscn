[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/IntelBag.gd" id="1_bag"]

[node name="IntelBag" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_bag")

[node name="TopBar" type="HBoxContainer" parent="."]
custom_minimum_size = Vector2(0, 60)
layout_mode = 1
anchors_preset = 10
anchor_right = 1.0
grow_horizontal = 2
theme_override_constants/separation = 20
alignment = 0

[node name="BackBtn" type="Button" parent="TopBar"]
layout_mode = 2
text = " 返回 "

[node name="Spacer1" type="Control" parent="TopBar"]
layout_mode = 2
size_flags_horizontal = 3

[node name="StaminaLabel" type="Label" parent="TopBar"]
layout_mode = 2
