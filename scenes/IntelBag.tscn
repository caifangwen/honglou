[node name="SellPopup" type="ConfirmationDialog" parent="."]
title = "出售情报"
size = Vector2i(450, 350)
unresizable = true

[node name="VBox" type="VBoxContainer" parent="SellPopup"]
offset_left = 8.0
offset_top = 8.0
offset_right = 442.0
offset_bottom = 301.0
theme_override_constants/separation = 15

[node name="Title" type="Label" parent="SellPopup/VBox"]
layout_mode = 2
