[node name="BuyerList" type="OptionButton" parent="SellPopup/VBox"]
layout_mode = 2

[node name="ToastLabel" type="Label" parent="."]
visible = false
layout_mode = 1
anchors_preset = 8
anchor_left = 0.5
anchor_top = 0.5
anchor_right = 0.5
anchor_bottom = 0.5
