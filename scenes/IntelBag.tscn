text = "精力: 8/8"

[node name="QiShuLabel" type="Label" parent="TopBar"]
layout_mode = 2
theme_override_font_sizes/font_size = 20
text = "气数: 100"

[node name="Spacer2" type="Control" parent="TopBar"]
layout_mode = 2
size_flags_horizontal = 3

[node name="InboxBtn" type="Button" parent="TopBar"]
layout_mode = 2
text = " 门房信箱 "

[node name="Middle" type="Control" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
offset_top = 70.0
offset_bottom = -80.0
grow_horizontal = 2
grow_vertical = 2

[node name="ScrollContainer" type="ScrollContainer" parent="Middle"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
horizontal_scroll_mode = 0

[node name="FragmentList" type="VBoxContainer" parent="Middle/ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 5

[node name="BottomBar" type="HBoxContainer" parent="."]
custom_minimum_size = Vector2(0, 80)
layout_mode = 1
anchors_preset = 12
anchor_top = 1.0
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 0
theme_override_constants/separation = 20
alignment = 1

[node name="ListenBtn" type="Button" parent="BottomBar"]
custom_minimum_size = Vector2(200, 50)
layout_mode = 2
text = "前往挂机监听"

[node name="MarketBtn" type="Button" parent="BottomBar"]
custom_minimum_size = Vector2(200, 50)
layout_mode = 2
text = "前往蜂腰桥集市"

[node name="DetailPopup" type="AcceptDialog" parent="."]
title = "情报详情"
size = Vector2i(400, 300)
unresizable = true

[node name="VBox" type="VBoxContainer" parent="DetailPopup"]
offset_left = 8.0
offset_top = 8.0
offset_right = 392.0
offset_bottom = 251.0
theme_override_constants/separation = 10

[node name="ContentLabel" type="Label" parent="DetailPopup/VBox"]
layout_mode = 2
