[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/InboxUI.gd" id="1"]

[node name="Inbox" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1")

[node name="Header" type="HBoxContainer" parent="."]
layout_mode = 1
anchor_right = 1.0
offset_bottom = 50.0
theme_override_constants/separation = 20

[node name="BackBtn" type="Button" parent="Header"]
layout_mode = 2
text = " 返回 "

[node name="TitleLabel" type="Label" parent="Header"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_font_sizes/font_size = 24
text = "门房收件箱"
horizontal_alignment = 1

[node name="UnreadCount" type="Label" parent="Header"]
layout_mode = 2
theme_override_colors/font_color = Color(1, 0, 0, 1)
text = "未读: 0"

[node name="BtnCompose" type="Button" parent="Header"]
layout_mode = 2
text = " 撰写 "

[node name="Tabs" type="HBoxContainer" parent="."]
layout_mode = 1
anchor_top = 0.08
anchor_right = 1.0
anchor_bottom = 0.15
theme_override_constants/separation = 10
alignment = 1

[node name="All" type="Button" parent="Tabs"]
layout_mode = 2
text = " 全部 "

[node name="Private" type="Button" parent="Tabs"]
layout_mode = 2
text = " 私信 "

[node name="Rumor" type="Button" parent="Tabs"]
layout_mode = 2
text = " 流言 "

[node name="System" type="Button" parent="Tabs"]
layout_mode = 2
text = " 系统 "

[node name="ScrollContainer" type="ScrollContainer" parent="."]
layout_mode = 1
anchor_top = 0.16
anchor_right = 1.0
anchor_bottom = 0.95

[node name="MessageList" type="VBoxContainer" parent="ScrollContainer"]
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 10

[node name="EmptyState" type="Label" parent="."]
visible = false
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
text = "门房清净，暂无来信。"
horizontal_alignment = 1
vertical_alignment = 1

[connection signal="pressed" from="Header/BackBtn" to="." method="_on_BackBtn_pressed"]
