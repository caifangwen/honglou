; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="红楼回忆志"
run/main_scene="res://scenes/Main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

GameTime="*res://autoload/GameTime.gd"
GameConfig="*res://scripts/data/GameConfig.gd"
GameState="*res://scripts/autoload/GameState.gd"
PlayerState="*res://scripts/autoload/PlayerState.gd"
FirebaseManager="*res://scripts/autoload/FirebaseManager.gd"
EventBus="*res://scripts/autoload/EventBus.gd"
SupabaseManager="*res://scripts/autoload/SupabaseManager.gd"
StaminaManager="*res://scripts/autoload/StaminaManager.gd"
EavesdropManager="*res://scripts/autoload/EavesdropManager.gd"
RelationshipManager="*res://scripts/autoload/RelationshipManager.gd"
MaidProgressionChecker="*res://scripts/autoload/MaidProgressionChecker.gd"
InboxManager="*res://scripts/inbox/InboxManager.gd"
PowerInfluence="*res://scripts/systems/PowerInfluence.gd"

[input]

toggle_debug_panel={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194313,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
