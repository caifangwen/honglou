; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Honglou Yihui Zhi"
run/main_scene="res://scenes/main/Main.tscn"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="res://icon.svg"

[autoload]

DebugTimePanel="*res://scenes/debug/DebugTimePanel.tscn"
GameTime="*res://core/GameTime.gd"
GameConfig="*res://core/GameConfig.gd"
GameState="*res://core/GameState.gd"
PlayerState="*res://core/PlayerState.gd"
EventBus="*res://core/EventBus.gd"
StaminaManager="*res://core/StaminaManager.gd"
SupabaseManager="*res://services/supabase/SupabaseManager.gd"
MockDatabase="*res://services/supabase/MockDatabase.gd"
EavesdropManager="*res://features/eavesdrop/EavesdropManager.gd"
RelationshipManager="*res://features/relationship/RelationshipManager.gd"
MaidProgressionChecker="*res://features/relationship/MaidProgressionChecker.gd"
InboxManager="*res://features/inbox/InboxManager.gd"
PowerInfluence="*res://features/power/PowerInfluence.gd"
DuiShiEvents="*res://features/relationship/DuiShiEvents.gd"

[input]

toggle_debug_panel={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194313,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
toggle_pause={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194312,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
speed_up={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":false,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194311,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}
reset_speed={
"deadzone": 0.5,
"events": [Object(InputEventKey,"resource_local_to_scene":false,"resource_name":"","device":-1,"window_id":0,"alt_pressed":false,"shift_pressed":false,"ctrl_pressed":true,"meta_pressed":false,"pressed":false,"keycode":0,"physical_keycode":4194311,"key_label":0,"unicode":0,"location":0,"echo":false,"script":null)
]
}

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
renderer/rendering_method="mobile"
